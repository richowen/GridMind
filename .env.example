# GridMind minimal .env
# All other settings (Home Assistant, Octopus Energy, InfluxDB, etc.)
# are stored in the database and editable via the Settings page in the UI.

# ── External MariaDB (required at startup) ─────────────────────────────────
# Point these at your existing MariaDB instance on Unraid.
# The 'gridmind' database and user must already exist.
DB_HOST=192.168.1.2
DB_PORT=3306
DB_USER=gridmind
DB_PASSWORD=your_secure_password
DB_NAME=gridmind

# ── Log level (requires container restart to change) ───────────────────────
LOG_LEVEL=INFO
