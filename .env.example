# GridMind environment variables
# Copy this file to .env and fill in your values.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=192.168.1.2
DB_PORT=3306
DB_USER=gridmind
DB_PASSWORD=your_db_password
DB_NAME=gridmind

# ── Log level (requires container restart to change) ───────────────────────
LOG_LEVEL=INFO

# ── CORS (requires container restart to change) ────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use "*" for development (default). Set to your frontend URL in production.
# Example: CORS_ORIGINS=http://192.168.1.76:3009
CORS_ORIGINS=*
